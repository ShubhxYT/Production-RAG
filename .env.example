# === LLM Provider Keys (at least one required) ===
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# === Database ===
# For local dev: use localhost
# For Docker Compose: use "db" (the service name)
DATABASE_URL=postgresql+psycopg://fullrag:fullrag@localhost:5432/fullrag

# === Generation Settings ===
GENERATION_PROVIDER=gemini
GENERATION_MODEL=gemini-2.5-flash
GENERATION_TEMPERATURE=0.3
GENERATION_MAX_TOKENS=2048

# === Groq (if GENERATION_PROVIDER=groq) ===
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FILE=/app/logs/fullrag.log

# === Cache ===
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=256
RESPONSE_CACHE_ENABLED=true

# === Evaluation ===
CONTINUOUS_EVAL_ENABLED=true
EVAL_SCHEDULE_INTERVAL_HOURS=24

# === Transcript Fallback ===
TRANSCRIPT_FALLBACK_ENABLED=true
TRANSCRIPT_PATH=data/transcript.md
